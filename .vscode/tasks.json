{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C++ Backend",
      "type": "shell",
      "command": "g++",
      "args": ["main.cpp", "-o", "main.exe"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Run C++ Backend",
      "type": "shell",
      "command": ".\\main.exe",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "dependsOn": "Build C++ Backend"
    }
  ]
}